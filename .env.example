# Docker Compose project name
COMPOSE_PROJECT_NAME=yak-ops

# Frontend Nginx image
YAK_OPS_IMAGE=weifuwan/yak-ops:1.0.0

# Backend Spring Boot image
YAK_OPS_API_IMAGE=weifuwan/yak-ops-api:1.0.0

# Browser access address:
# http://localhost:9001
YAK_OPS_PORT=9001


# =========================
# MySQL
# =========================

MYSQL_ROOT_PASSWORD=seatunnel_root_password
MYSQL_DATABASE=baize_flow
MYSQL_USER=seatunnel
MYSQL_PASSWORD=seatunnel_password

# MySQL address used inside the Docker network.
# Do not change this to localhost.
MYSQL_HOST=mysql
MYSQL_PORT=3306

# MySQL port exposed on the host.
# Use 3306 because the local 3306 port is already occupied.
MYSQL_HOST_PORT=3306


# =========================
# JVM
# =========================

JAVA_OPTS=-Xms512m -Xmx1024m

# Additional Spring Boot arguments
APP_OPTS=


# =========================
# Security
# =========================

# Used to encrypt datasource passwords with AES-GCM.
# Generate a new value before production deployment.
YAK_OPS_DATASOURCE_MASTER_KEY=replace_with_a_random_32_byte_secret_key