# Frontend Nginx image
YAK_OPS_IMAGE=yak-ops:local

# Backend image
YAK_OPS_API_IMAGE=yak-ops-api:local

# Browser access port
YAK_OPS_PORT=9001

# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306

# JVM
JAVA_OPTS=-Xms512m -Xmx1024m

# Spring Boot additional arguments
APP_OPTS=
# Master key used to AES-GCM encrypt datasource passwords. Replace before production use.
YAK_OPS_DATASOURCE_MASTER_KEY=change_me
