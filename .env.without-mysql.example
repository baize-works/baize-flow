# Frontend Nginx image
BAIZE_FLOW_IMAGE=baize-flow:local

# Backend image
BAIZE_FLOW_API_IMAGE=baize-flow-api:local

# Browser access port
BAIZE_FLOW_PORT=9001

# MySQL
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306

# JVM
JAVA_OPTS=-Xms512m -Xmx1024m

# Spring Boot additional arguments
APP_OPTS=
# Master key used to AES-GCM encrypt datasource passwords. Replace before production use.
BAIZE_FLOW_DATASOURCE_MASTER_KEY=change_me
